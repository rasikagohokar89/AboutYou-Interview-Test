{
  "name": "aboutyou-checkout-qa",
  "version": "1.0.0",
  "description": "QA Automation Test Suite for About You Checkout Flow — Playwright + TypeScript",
  "scripts": {
    "test": "npx playwright test",
    "test:checkout": "npx playwright test tests/checkout/",
    "test:basket": "npx playwright test tests/basket/",
    "test:api": "npx playwright test tests/api/",
    "test:smoke": "npx playwright test --grep @smoke",
    "test:regression": "npx playwright test --grep @regression",
    "test:edge": "npx playwright test --grep @edge-case",
    "test:negative": "npx playwright test --grep @negative",
    "test:chromium": "npx playwright test --project=chromium",
    "test:firefox": "npx playwright test --project=firefox",
    "test:webkit": "npx playwright test --project=webkit",
    "test:headed": "npx playwright test --headed",
    "test:debug": "npx playwright test --debug",
    "test:ui": "npx playwright test --ui",
    "report": "npx playwright show-report",
    "setup": "npx playwright install --with-deps"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.0",
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.1",
    "dotenv": "^16.5.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
