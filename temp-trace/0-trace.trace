77500"},["SPAN",{"class":"sc-5efa0c3d-2 iVouRR"},["I",{"data-testid":"PromiseBarIcon","size":"3","class":"sc-1e6655f3-1 sc-5efa0c3d-4 gJOjMb cyZcdz"}],["SPAN",{"class":"sc-5efa0c3d-3 cyIHc"},"Free Delivery* & Returns"]]]],["LI",{},["A",{"data-testid":"LinkToUrl","target":"_blank","class":"sc-5efa0c3d-1 fWVZyy","href":"/h/shipping-delivery/q-360014777500"},["SPAN",{"class":"sc-5efa0c3d-2 iVouRR"},["I",{"data-testid":"PromiseBarIcon","size":"3","class":"sc-1e6655f3-1 sc-5efa0c3d-4 jXxeVb cyZcdz"}],["SPAN",{"class":"sc-5efa0c3d-3 cyIHc"},"Fast delivery"]]]],["LI",{},["A",{"data-testid":"LinkToUrl","target":"_blank","class":"sc-5efa0c3d-1 fWVZyy","href":"/h/shipping-delivery/q-360014777500"},["SPAN",{"class":"sc-5efa0c3d-2 iVouRR"},["I",{"data-testid":"PromiseBarIcon","size":"3","class":"sc-1e6655f3-1 sc-5efa0c3d-4 cYexoO cyZcdz"}],["SPAN",{"class":"sc-5efa0c3d-3 cyIHc"},"30 day Return Policy"]]]]],["SECTION",{"class":"sc-b31f925d-3 kVZhFz"},["ARTICLE",{"data-testid":"ContentGenderSelectBanner","class":"sc-b31f925d-4 bogxQQ"},["IMG",{"__playwright_current_src__":"https://cdn.aboutstatic.com/file/images/d7d31f991fbf9d43243cdb57b30ebc43.jpg?width=1500&quality=90","data-testid":"Image","alt":"","class":"sc-22c6c9ae-0 hfwmge sc-b31f925d-0 iKzdmQ","height":"100","width":"100","src":"//cdn.aboutstatic.com/file/images/d7d31f991fbf9d43243cdb57b30ebc43.jpg?width=1500&quality=90"}],["DIV",{"class":"sc-b31f925d-5 imFPFG"},["DIV",{"class":"sc-b31f925d-7 bEykGV"},["H2",{"class":"sc-b31f925d-10 bJSrLE"},"Your new fashion experience"],["H3",{"class":"sc-b31f925d-12 fekprx"},"Discover our great style and brand variety that fits you perfectly."],["DIV",{"class":"sc-b31f925d-8 jwcOPb"},["A",{"data-testid":"Link","href":"/women/clothing","class":"sc-30b856db-0 sc-b31f925d-9 jmGaNq cQUcKg"},"Women"],["A",{"data-testid":"Link","href":"/men/clothing","class":"sc-30b856db-0 sc-b31f925d-9 jmGaNq cQUcKg"},"Men"],["A",{"data-testid":"Link","href":"/kids","class":"sc-30b856db-0 sc-b31f925d-9 jmGaNq cQUcKg"},"Kids"]]]]],["ARTICLE",{"data-testid":"ContentUspBanner","class":"sc-b31f925d-4 kEbhgG"},["A",{"href":"https://en.aboutyou.de/s/celebrity-collections-7779?force-language=1"},["IMG",{"__playwright_current_src__":"https://cdn.aboutstatic.com/file/images/af209cb26dfa04fac985d0d0d2b57c8f.jpg?width=1000&quality=90","data-testid":"Image","alt":"","class":"sc-22c6c9ae-0 hfwmge sc-b31f925d-1 bstSav","height":"100","width":"100","src":"//cdn.aboutstatic.com/file/images/af209cb26dfa04fac985d0d0d2b57c8f.jpg?width=1000&quality=90"}],["DIV",{"class":"sc-b31f925d-5 gEulfx"},["DIV",{"class":"sc-b31f925d-6 gOwCOT"},["DIV",{"class":"sc-b31f925d-7 bEykGV"},["H2",{"class":"sc-b31f925d-11 bezmcR"},"We have them all!"],["H3",{"class":"sc-b31f925d-13 gWbvob"},"Shop our Celebrity Collections by ABOUT YOU"]]]]]]],["SECTION",{"class":"sc-b31f925d-14 dFJNtt"},["DIV",{"data-testid":"TopBrandsContentFocus","class":"sc-b004bcda-0 hwEQRd"}]],["SECTION",{"class":"sc-c7cef127-0 EaSYR"},["ARTICLE",{"class":"sc-c7cef127-1 gCpbby"},["H2",{"class":"sc-c7cef127-2 ihGuxC"},"Large selection, easy ordering – online ladieswear on ABOUT YOU"],["P",{"class":"sc-c7cef127-3 iqHEEx"},"Women and shopping go together like no other, which is why ABOUT YOU knows women's fashion best of all. Our large selection of diverse brands has everything you need for your next outfit: from A for accessory to Z for zipper. Browse the latest trends or let yourself be inspired by classic cuts and models. Your order will be delivered to your house quickly and conveniently. And if one of the items is not to your taste, you can return it free of charge."]],["ARTICLE",{"class":"sc-c7cef127-1 gCpbby"},["H2",{"class":"sc-c7cef127-2 ihGuxC"},"Jackets and outerwear – Women's fashion to suit your taste"],["P",{"class":"sc-c7cef127-3 iqHEEx"},"Whether it's a blouse, dress, or t-shirt you're after, ABOUT YOU has everything you need to round off your look. We offer a wide selection of sizes and colors. Our vibrantly colored pieces will make you long for summer while our understated tops will help you cut a good figure during the chilly season. While you're at it, you can order a matching jacket to help keep the cold out this winter. Innovative features such as a removable lining, thick hood, and extra-tailored fit make our jackets and coats an absolute wardrobe essential."]],["ARTICLE",{"class":"sc-c7cef127-1 gCpbby"},["H2",{"class":"sc-c7cef127-2 ihGuxC"},"Dress up your legs"],["P",{"class":"sc-c7cef127-3 iqHEEx"},"On the lookout for pants to suit a special occasion or to complete your wardrobe? Then have a look around ABOUT YOU. Our large selection of pants includes trendy boyfriend jeans and classic cloth pants. Find the right size in any brand with the help of our size advisor. Just enter the size of your own pair of pants and find the manufacturer's specific size for a particular model with a simple click of the button. It doesn't get any easier than this.\n"]],["ARTICLE",{"class":"sc-c7cef127-1 gCpbby"},["H2",{"class":"sc-c7cef127-2 ihGuxC"},"Every woman's essentials"],["P",{"class":"sc-c7cef127-3 iqHEEx"},"Whether it's high heels, sneakers or pumps, shoes simply exert a magical fascination over women. ABOUT YOU carries all the right spring, summer, autumn, and winter footwear. Our colorful models will make you look forward to the warm season and our boots will keep you warm and comfortable during the autumn and winter months."]],["ARTICLE",{"class":"sc-c7cef127-1 gCpbby"},["H2",{"class":"sc-c7cef127-2 ihGuxC"},"Accessories to complete your outfit"],["P",{"class":"sc-c7cef127-3 iqHEEx"},"What would women's fashion be without accessories? Jewelry, sunglasses, hats, and bags can turn the most boring basics into a fantastic outfit. If you have questions regarding your oder, please contact the ABOUT YOU consulting team."]],["P",{"class":"sc-c7cef127-3 iqHEEx"},"*"," "]]]]],["FOOTER",{"data-testid":"footer","class":"f13s5f1f","style":"--f13s5f1f-0:3rem"},[[12,1481]],[[12,1491]],[[12,1578]]